{
  "buildCommand": "node .v0/inject-built-with-v0.mjs && next build",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "etfflow.kr"
        }
      ],
      "destination": "https://www.etfflow.kr/:path*",
      "permanent": true
    }
  ]
}
